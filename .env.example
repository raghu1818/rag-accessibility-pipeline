# ── Required ──────────────────────────────────────────────────────────────────
# Never commit a real key. Use a secrets manager in production.
OPENAI_API_KEY=sk-...

# ── Optional overrides (defaults shown) ──────────────────────────────────────
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

FAISS_INDEX_PATH=data/processed/faiss_index
FAISS_TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
LOG_LEVEL=INFO
ENVIRONMENT=development

TESSERACT_CMD=tesseract
OCR_LANGUAGE=eng
OCR_DPI=300

UPLOAD_DIR=data/raw
MAX_UPLOAD_SIZE_MB=50
